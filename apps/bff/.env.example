NODE_ENV=development
PORT=3000

FRONTEND_ORIGIN=http://localhost:4200

API_PREFIX=api
API_VERSION=1

CLERK_WEBHOOK_SECRET=

# user-service (Nest TCP; required — no defaults in app; `USER_SERVICE_TCP_PORT` must match `TCP_PORT` in apps/user-service/.env*)
USER_SERVICE_HOST=127.0.0.1
USER_SERVICE_TCP_PORT=4001

DATABASE_URL=postgresql://zenith:zenith@localhost:5432/zenith

# pgAdmin (after docker:setup): http://localhost:5050 — admin@zenith.local / admin
# Register server: Host postgres, Port 5432, User zenith, Password zenith, DB zenith

REDIS_URL=redis://localhost:6379

MONGODB_URI=mongodb://zenith:zenith@localhost:27017/?authSource=admin

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=zenith
MINIO_SECRET_KEY=zenithzenith
MINIO_BUCKET=zenith
